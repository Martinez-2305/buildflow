# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets here (see git history
# for why: an old webhook secret was hardcoded into a migration and had
# to be rotated after the fact).
#
# These values are NOT used by the static site itself (it has no build
# step). They're local storage for Supabase CLI / dashboard config:
#   supabase secrets set --env-file .env --project-ref $SUPABASE_PROJECT_REF

# Supabase project ref (from the project URL, e.g. https://<ref>.supabase.co)
SUPABASE_PROJECT_REF=xzzflafruciaqvwfszju

# Personal access token for the Supabase CLI (generate at
# https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=

# Edge Function secrets — must also be set in Supabase Dashboard ->
# Project Settings -> Edge Functions -> Secrets (or via `supabase secrets set`)
WEBHOOK_SECRET=
RESEND_API_KEY=
